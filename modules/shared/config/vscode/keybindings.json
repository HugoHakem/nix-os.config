[ // define keybindings here
  {
    "key": "alt+x o",
    "command": "workbench.action.terminal.moveIntoNewWindow",
    "when": "terminalHasBeenCreated && terminalIsOpen || terminalIsOpen && terminalProcessSupported"
  },
  {
    "key": "ctrl+shift+u",
    "command": "editor.action.transformToUppercase"
  },
  {
    "key": "ctrl+shift+l",
    "command": "editor.action.transformToLowercase"
  },
  {
    "key": "ctrl+shift+k",
    "command": "editor.action.transformToKebabcase"
  },
  {
    "key": "ctrl+shift+p",
    "command": "editor.action.transformToPascalcase"
  },
  {
    "key": "ctrl+shift+s",
    "command": "editor.action.transformToSnakecase"
  },
  {
    "key": "alt+x shift+r",
    "command": "ruff.executeAutofix"
  },
  {
    "key": "ctrl+cmd+o",
    "command": "workbench.action.chat.openInNewWindow"
},
{
    "key": "shift+enter",
    "command": "workbench.action.terminal.sendSequence",
    "args": {
        "text": "\u001b\r"
    },
    "when": "terminalFocus"
},
{
  "key": "alt+x t",
  "command": "workbench.action.terminal.moveToEditor",
  "when": "terminalHasBeenCreated && terminalIsOpen || terminalIsOpen && terminalProcessSupported"
}
]
